{
  "name": "koris-agent-monorepo",
  "private": true,
  "packageManager": "pnpm@8.5.1",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage --",
    "test:mutation": "turbo run test:mutation --",
    "dev": "turbo run dev --filter=koris-agent",
    "dev:tui": "turbo run dev:tui --filter=koris-agent",
    "start": "turbo run start --filter=koris-agent",
    "start:tui": "turbo run start:tui --filter=koris-agent"
  },
  "devDependencies": {
    "turbo": "^2.9.14"
  }
}
